# ─────────────────────────────────────────────────────────────────────────────
# Arogya — production configuration.
# Copy this file to ".env" (same folder) and fill in every value.
# NEVER commit the real .env — it holds your secrets.
# ─────────────────────────────────────────────────────────────────────────────

# 1) YOUR THREE DOMAINS ───────────────────────────────────────────────────────
# Create these DNS "A" records pointing at this server's public IP address.
APP_DOMAIN=app.arogya.in         # patient app
PORTAL_DOMAIN=portal.arogya.in   # pharmacy portal
API_DOMAIN=api.arogya.in         # backend API

# Email for Let's Encrypt certificate notices (use a real inbox).
ACME_EMAIL=you@example.com

# 2) DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_USER=saathipill
POSTGRES_DB=saathipill
# Generate a strong password, e.g.  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# 3) SECRETS  (generate with ./scripts/generate-secrets.sh) ───────────────────
# Long random string used to sign login tokens.  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_string
JWT_EXPIRES=30m

# Web-Push (VAPID) keys for desktop/phone notifications.
# Generate with:  docker run --rm node:20-alpine npx --yes web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME_vapid_public_key
VAPID_PRIVATE_KEY=CHANGE_ME_vapid_private_key
VAPID_SUBJECT=mailto:care@arogya.in

# 4) SMS / OTP  (optional — leave blank to show the OTP on screen for testing) ─
# When set, OTPs and caregiver/pharmacy messages are delivered by real SMS and
# are no longer revealed in the API response.
SMS_PROVIDER=
MSG91_AUTH_KEY=

# 5) TIMEZONE ─────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata
