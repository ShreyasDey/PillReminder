# Copy to .env and fill in. docker-compose provides DATABASE_URL automatically.
DATABASE_URL="postgresql://saathipill:saathipill@localhost:5432/saathipill?schema=public"
PORT=3000
NODE_ENV=development

# Change this to a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES="30m"

# Comma-separated list of allowed front-end origins.
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# SMS / OTP delivery (leave unset in dev — OTP is shown on screen).
# SMS_PROVIDER="msg91"
# MSG91_AUTH_KEY=""
